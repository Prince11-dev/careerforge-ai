# CareerForge AI - Environment Configuration

# Application
APP_NAME=CareerForge AI
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# Use SQLite for local development (set DATABASE_URL to sqlite path)
# Use PostgreSQL for production
DATABASE_URL=sqlite:///./careerforge.db
# DATABASE_URL=postgresql://user:password@localhost/careerforge

# AI Provider
# Set to "openai" for OpenAI, "mock" for deterministic mock mode
AI_PROVIDER=mock
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Mock AI Mode (fallback when no API key available)
MOCK_AI_MODE=true

# CORS
FRONTEND_URL=http://localhost:5173

# File Uploads
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=uploads
